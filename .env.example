# ============================================================================
# Supabase
# ============================================================================
# Public — exposed to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by webhook handler, NFS-e issuance, scheduled jobs
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# Mercado Pago
# ============================================================================
# Test keys: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
# Webhook signing secret — set this on the Mercado Pago dashboard, used to
# verify x-signature headers
MP_WEBHOOK_SECRET=

# ============================================================================
# PlugNotas (NFS-e)
# ============================================================================
# Sandbox keys: https://app.plugnotas.com.br
PLUGNOTAS_API_KEY=
PLUGNOTAS_BASE_URL=https://api.sandbox.plugnotas.com.br

# ============================================================================
# Resend (transactional email — ticket delivery, refund confirmations)
# ============================================================================
RESEND_API_KEY=
RESEND_FROM="Ingressos <ingressos@yourdomain.com>"

# ============================================================================
# App
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 32+ random chars — used to sign session cookies for anonymous checkout flows
SESSION_SECRET=
